{
  "name": "backdating-git",
  "displayName": "Backdating Git",
  "icon": "icon.svg",
  "description": "Create Git commits with custom backdated timestamps.",
  "version": "1.0.3",
  "publisher": "Nathnael Nigussie",
  "repository": {
    "type": "git",
    "url": "https://github.com/nathnael19/backdating-git-vs-code-extension.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "commit",
    "backdate",
    "history",
    "timestamp",
    "sidebar",
    "gui"
  ],
  "activationEvents": [
    "onView:backdating-git.sidebar",
    "onCommand:backdating-git.commit"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "backdating-git.commit",
        "title": "Backdating Git: Commit"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "backdating-git-container",
          "title": "Backdating Git",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "backdating-git-container": [
        {
          "type": "webview",
          "id": "backdating-git.sidebar",
          "name": "Commit Options"
        }
      ]
    }
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.35"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^18.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
